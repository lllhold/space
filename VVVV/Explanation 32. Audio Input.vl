          <Pad Id="OPoUkEDVYDhLxQCF3hskKg" Bounds="592,763,163,31" ShowValueBox="true" isIOBox="true" Value="Meter">
            <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
